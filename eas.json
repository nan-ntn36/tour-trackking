        "EXPO_PUBLIC_ORS_API_KEY": "",
        "GOOGLE_API_KEY": ""
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
